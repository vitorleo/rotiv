{
  "name": "@rotiv/create",
  "version": "0.1.0",
  "private": false,
  "description": "Create a new Rotiv project (npx create-rotiv)",
  "bin": {
    "create-rotiv": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --project tsconfig.build.json"
  },
  "dependencies": {
    "@rotiv/types": "workspace:*",
    "@rotiv/spec": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^22.0.0"
  }
}
