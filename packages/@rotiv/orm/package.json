{
  "name": "@rotiv/orm",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "description": "Rotiv model DSL and typed query builder — wraps Drizzle ORM",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --project tsconfig.json",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.0",
    "better-sqlite3": "^9.0.0",
    "pg": "^8.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.0.0",
    "@types/pg": "^8.0.0",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
